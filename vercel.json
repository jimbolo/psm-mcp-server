{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/standalone.js",
      "dest": "/standalone.js",
      "headers": {
        "Content-Type": "application/javascript",
        "Content-Disposition": "attachment; filename=postscan-mail-mcp-server.js",
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
