{
  "name": "postscan-mail-mcp-server",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/standalone.js",
  "scripts": {
    "dev": "nodemon",
    "build": "npm run clean:dist && npm run bundle:standalone",
    "build:full": "tsc",
    "clean:dist": "node -e \"const fs=require('fs'); if(fs.existsSync('dist')) fs.rmSync('dist', {recursive:true, force:true}); fs.mkdirSync('dist', {recursive:true});\"",
    "build:watch": "tsc --watch",
    "build:bundle": "npm run build && npm run bundle",
    "bundle": "esbuild dist/index.js --bundle --platform=node --format=esm --outfile=dist/index.bundle.js --external:node:*",
    "bundle:standalone": "esbuild ./src/index.ts --bundle --platform=node --format=esm --outfile=./dist/standalone.js --external:node:*",
    "update-mcp": "npm run bundle:standalone && echo MCP bundle updated! Please restart VS Code/Claude.",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "start:bundle": "node dist/index.bundle.js",
    "start:standalone": "node dist/standalone.js",
    "clean": "node -e \"const fs=require('fs'); if(fs.existsSync('dist')) fs.rmSync('dist', {recursive:true, force:true});\"",
    "test": "node test/scripts/run-all.js",
    "test:unit": "node test/scripts/run-unit.js",
    "test:integration": "node test/scripts/run-integration.js",
    "test:functional": "node test/scripts/run-functional.js",
    "test:quick": "node test/scripts/quick-validation.js",
    "test:final": "node test/scripts/final-validation.js",
    "test:jest": "jest --config test/config/jest.config.js",
    "test:watch": "jest --config test/config/jest.config.js --watch",
    "test:coverage": "jest --config test/config/jest.config.js --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "prepare": "npm run build",
    "docs": "typedoc src --out docs",
    "debug": "node --inspect-brk dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "markdown-it": "^14.1.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "esbuild": "^0.25.8",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.0.5",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  }
}
